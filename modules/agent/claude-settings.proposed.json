{
  "_comment": "PROPOSED Claude Code settings for the `claude` agent (STAGED — not live). Install into the agent's Claude Code config (e.g. ~/.claude/settings.json for the claude user, or the project .claude/settings.json) and adjust paths. Rules evaluate deny -> ask -> allow; first match wins. The PreToolUse hook is the programmatic backstop. See ./README.md and ./pretooluse-guard.sh.",

  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(systemctl status:*)",
      "Bash(systemctl is-active:*)",
      "Bash(systemctl is-failed:*)",
      "Bash(systemctl list-units:*)",
      "Bash(systemctl list-timers:*)",
      "Bash(journalctl:*)",
      "Bash(ss:*)",
      "Bash(ip:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout -b:*)",
      "Bash(nixos-rebuild build:*)",
      "Bash(nixos-rebuild dry-build:*)",
      "Bash(nix flake check:*)"
    ],

    "ask": [
      "Edit",
      "Write",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(sudo:*)",
      "Bash(systemctl restart:*)",
      "Bash(media-mirror sync:*)"
    ],

    "deny": [
      "Bash(rm:*)",
      "Bash(sudo rm:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(sudo nixos-rebuild switch:*)",
      "Bash(sudo nixos-rebuild boot:*)",
      "Bash(git push:* --force:*)",
      "Bash(git push:* main:*)",
      "Bash(:* /dev/sd:*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "/home/claude/.claude/pretooluse-guard.sh" }
        ]
      }
    ]
  }
}
